# ---------------------------------------------------------
# StudyHub AI — Client environment variables
# Copy this file to .env for local development.
# In production (Vercel), set VITE_API_URL in the Vercel
# project's Environment Variables settings.
#
# Only VITE_-prefixed variables are exposed to the browser
# bundle by Vite — never put secrets here.
# ---------------------------------------------------------

# Local dev: your local backend
VITE_API_URL=http://localhost:5000/api

# Production example:
# VITE_API_URL=https://studyhub-ai-api.onrender.com/api
