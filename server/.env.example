# ---------------------------------------------------------
# StudyHub AI — Server environment variables
# Copy this file to .env for local development.
# In production (Render), set these in the Render Dashboard
# under your service's "Environment" tab — do NOT commit
# a real .env file.
# ---------------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# e.g. mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/studyhub-ai?retryWrites=true&w=majority
MONGODB_URI=

# JWT
JWT_SECRET=
# Reserved for a future refresh-token flow. The current codebase issues a
# single long-lived access token and does not use a refresh token yet, but
# the variable is included here so the value can be provisioned ahead of time.
JWT_REFRESH_SECRET=

# Groq API (AI features: summaries, quizzes, flashcards, chat, mindspace)
GROQ_API_KEY=

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend origin(s) allowed by CORS.
# Comma-separate multiple origins, e.g.:
# CLIENT_URL=https://studyhub-ai.vercel.app,https://www.studyhub-ai.com
CLIENT_URL=http://localhost:5173
